APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Use 'local' for development without S3; set to 's3' for production.
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS credentials — do NOT set ACCESS_KEY/SECRET on EC2; use instance IAM role.
# For local dev: configure AWS SSO (`aws configure sso`) and set the profile name below.
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_PROFILE=

# --- RDS IAM Authentication ---
# On EC2: credentials come from the instance IAM role automatically (no key needed).
# For local dev with SSO: set AWS_PROFILE above instead of key/secret.
# Set DB_CONNECTION=rds_mysql (or rds_pgsql) on production to use these.
RDS_IAM_AUTH=false
RDS_HOST=
RDS_PORT=3306
RDS_DATABASE=laravel
RDS_USERNAME=
RDS_DRIVER=mysql
RDS_CA_BUNDLE=

VITE_APP_NAME="${APP_NAME}"
