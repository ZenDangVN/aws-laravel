APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
TRUSTPROXIES_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
# Use 'local' for development without S3; set to 's3' for production.
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# --- Redis / AWS ElastiCache Serverless Valkey ---
# Local dev: REDIS_SCHEME=tcp (no TLS), REDIS_CLIENT=predis
# Production (ElastiCache Serverless): REDIS_SCHEME=tls, SESSION_DRIVER=redis, CACHE_STORE=redis, QUEUE_CONNECTION=redis
# ElastiCache Serverless does not support SELECT — both connections must use REDIS_DB=0
REDIS_CLIENT=predis
REDIS_SCHEME=tcp
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=0

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS credentials — do NOT set ACCESS_KEY/SECRET on EC2; use instance IAM role.
# For local dev: configure AWS SSO (`aws configure sso`) and set the profile name below.
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_PROFILE=
# CloudFront distribution URL for serving public files (avatars, etc.).
# When set, Storage::url() returns https://xxx.cloudfront.net/path instead of S3 direct URLs.
# Leave empty to fall back to: https://bucket.s3.region.amazonaws.com/path
CLOUDFRONT_URL=

# --- RDS IAM Authentication ---
# On EC2: credentials come from the instance IAM role automatically (no key needed).
# For local dev with SSO: set AWS_PROFILE above instead of key/secret.
# Set DB_CONNECTION=rds_mysql (or rds_pgsql) on production to use these.
RDS_IAM_AUTH=false
RDS_HOST=
RDS_PORT=3306
RDS_DATABASE=laravel
RDS_USERNAME=
RDS_DRIVER=mysql
RDS_CA_BUNDLE=
RDS_SSLMODE=verify-ca

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
